# =============================================================================
# Krutrim AI Chatbot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Krutrim API
# -----------------------------------------------------------------------------
# Your Krutrim Cloud API key.
# Obtain from: https://cloud.olakrutrim.com
# Used to authenticate requests to the Krutrim chat completions endpoint.
# Users can also provide their own key via the Profile page (stored in MongoDB).
KRUTRIM_API_KEY=your_krutrim_api_key_here

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Password for the MongoDB Atlas user named "chatbot".
# The username is hard-coded as "chatbot" in app.py; update there if different.
MONGO_PASS=your_mongodb_password_here

# The MongoDB database name that will hold users, chats, and chat metadata.
# Example: chatbotdb
MONGO_DB=your_database_name_here

# -----------------------------------------------------------------------------
# Google OAuth 2.0  (optional — only required for "Sign in with Google")
# -----------------------------------------------------------------------------
# Create OAuth 2.0 credentials in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Add http://localhost:8501 (and your production URL) to "Authorized redirect URIs".

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Port Streamlit listens on.
# Default: 8501
STREAMLIT_SERVER_PORT=8501

# The redirect URI that Google sends the user back to after login.
# Must exactly match one of the "Authorized redirect URIs" in Google Cloud Console.
# For local dev: http://localhost:8501
# For production: https://your-domain.com
OAUTH_REDIRECT_URI=http://localhost:8501

# -----------------------------------------------------------------------------
# Optional / Advanced
# -----------------------------------------------------------------------------
# The Prometheus metrics HTTP server runs on port 8000 by default.
# Access it at http://localhost:8000/metrics
# No configuration needed unless you want to change the port
# (edit app.py → start_http_server call).

# Web search is powered by DuckDuckGo (duckduckgo-search package).
# No API key required — install the package and it works out of the box.

# Document parsing (PDF, DOCX, XLSX) is handled by:
#   pypdf, python-docx, openpyxl  — all listed in requirements.txt.

# Image uploads are sent to the model as base64 data URLs (OpenAI vision format).
# Vision support depends on the selected model (e.g., multimodal models only).
